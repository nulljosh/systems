# Functions: fn/fn, return/return, recursion, defaults

# basic function
fn greet(name) {
    print "hello " + name
}
greet("world")

# return value
fn add(a, b) {
    return a + b
}
print add(3, 4)

# default parameters
fn say(msg, times = 2) {
    let i = 0
    while i < times {
        print msg
        i += 1
    }
}
say("hi")
say("yo", 1)

# recursion (fibonacci)
fn fib(n) {
    if n <= 1 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}
print fib(0)
print fib(1)
print fib(5)
print fib(10)

# fn keyword works too
fn double(x) {
    return x * 2
}
print double(7)

# fn keyword also maps to fn
fn triple(x) {
    return x * 3
}
print triple(5)

# functions as values
fn apply(f, val) {
    return f(val)
}
print apply(double, 10)

# nested function calls
print add(double(3), fib(4))
