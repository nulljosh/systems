# Standard keyword tests (replaces former Jungian alias tests)

# let
let x = 42
print x

# fn
fn square(n) {
    return n * n
}
print square(6)

# fn (another)
fn cube(n) {
    return n * n * n
}
print cube(3)

# class
class Hero {
    fn init(name) {
        this.name = name
    }
    fn quest() {
        return this.name + " embarks"
    }
}
let h = new Hero("Jung")
print h.quest()

# null
let void = null
print void

# try/catch/throw
try {
    throw "shadow appears"
} catch (e) {
    print e
}

# print
print "all keywords verified"

# more standard keywords
let y = 99
fn inc(n) {
    return n + 1
}
print inc(y)

class Point {
    fn init(x, y) {
        this.x = x
        this.y = y
    }
}
let p = new Point(3, 4)
print p.x
print p.y

try {
    throw "standard error"
} catch (e) {
    print "caught: " + e
}
