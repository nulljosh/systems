# True lexical closure tests + higher-order function tests.

# --- Functions as first-class values: pass to HOF ---
fn apply(f, val) {
    return f(val)
}

fn double(x) { return x * 2 }
fn square(x) { return x * x }
fn negate(x) { return x * -1 }

print apply(double, 7)
print apply(square, 5)
print apply(negate, 10)

# --- apply_twice: compose f with itself ---
fn apply_twice(f, x) {
    return f(f(x))
}
print apply_twice(double, 3)
print apply_twice(square, 2)

# --- Counter factory: true closure with mutable state ---
fn make_counter() {
    let count = 0
    fn increment() {
        count += 1
        return count
    }
    return increment
}

let c = make_counter()
print c()
print c()
print c()

# Two independent counters from same factory
let c1 = make_counter()
let c2 = make_counter()
c1()
c1()
print c1()
print c2()

# --- Closure over parameter ---
fn make_adder(x) {
    fn add(y) {
        return x + y
    }
    return add
}

let add5 = make_adder(5)
let add10 = make_adder(10)
print add5(3)
print add10(3)

# --- Nested closures ---
fn make_multiplier_adder(mult) {
    fn make_adder(base) {
        fn compute(x) {
            return mult * x + base
        }
        return compute
    }
    return make_adder
}

let double_plus = make_multiplier_adder(2)
let double_plus_10 = double_plus(10)
print double_plus_10(5)
print double_plus_10(0)

# --- Counter pattern via class (still works) ---
class Counter {
    fn init(start) {
        this.count = start
    }
    fn increment() {
        this.count += 1
        return this.count
    }
    fn decrement() {
        this.count -= 1
        return this.count
    }
    fn get() {
        return this.count
    }
    fn reset() {
        this.count = 0
    }
    fn add(n) {
        this.count += n
        return this.count
    }
}

let cc = new Counter(0)
print cc.increment()
print cc.increment()
print cc.increment()
print cc.get()
print cc.decrement()
print cc.get()
cc.reset()
print cc.get()
print cc.add(5)

let cc1 = new Counter(0)
let cc2 = new Counter(100)
print cc1.increment()
print cc2.decrement()
print cc1.get()
print cc2.get()

# --- Filter-like pattern ---
fn print_evens(arr) {
    for item in arr {
        if item % 2 == 0 {
            print item
        }
    }
}

print_evens([1, 2, 3, 4, 5, 6, 7, 8])

# --- Reduce-like pattern ---
fn reduce_sum(arr) {
    let acc = 0
    for item in arr {
        acc += item
    }
    return acc
}

print reduce_sum([1, 2, 3, 4, 5])
print reduce_sum([10, 20, 30])

fn sum_doubled(arr) {
    let acc = 0
    for item in arr {
        acc += item * 2
    }
    return acc
}
print sum_doubled([1, 2, 3, 4, 5])
