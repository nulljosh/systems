# Data structures: arrays, objects, methods

# array literals and indexing
let nums = [10, 20, 30]
print nums[0]
print nums[1]
print nums[2]

# push and pop (method syntax)
nums.push(40)
print nums
print nums.length()

# object literals
let person = {name: "Carl", role: "psychologist"}
print person.name
print person.role

# bracket access
print person["name"]

# property assignment
person.age = 65
print person.age

# nested structures
let data = {
    items: [1, 2, 3],
    meta: {count: 3}
}
print data.items
print data.meta.count

# iteration over array
for item in [100, 200, 300] {
    print item
}

# string methods
print "hello".upper()
print "WORLD".lower()
print "  trimmed  ".trim()
print "hello world".contains("world")
print "hello world".contains("xyz")
print "hello world".replace("world", "jot")
print "hello world".indexOf("world")

# array methods
let list = [1, 2, 3, 4, 5]
print list.includes(3)
print list.includes(9)
print [1, 2].concat([3, 4])
print [[1, 2], [3, 4]].flat()
print [1, 2, 3].indexOf(2)

# object methods
let config = {a: 1, b: 2}
print config.has("a")
print config.has("z")
