# If/else, while, for-in, break/continue

# if/else
let val = 10
if val > 5 {
    print "greater"
}

if val < 5 {
    print "less"
} else {
    print "not less"
}

# else if chain
let grade = 85
if grade >= 90 {
    print "A"
} else if grade >= 80 {
    print "B"
} else if grade >= 70 {
    print "C"
} else {
    print "F"
}

# while loop
let count = 0
while count < 5 {
    print count
    count += 1
}

# for-in over array
let fruits = ["apple", "banana", "cherry"]
for fruit in fruits {
    print fruit
}

# for-in over range
for i in range(3) {
    print "i=" + str(i)
}

# range with start/end
for i in range(5, 8) {
    print i
}

# break
let n = 0
while true {
    if n >= 3 {
        break
    }
    print "n=" + str(n)
    n += 1
}

# continue
for i in range(6) {
    if i % 2 == 0 {
        continue
    }
    print "odd: " + str(i)
}
