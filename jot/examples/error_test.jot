// Error handling test

print "=== Try/Catch Test ===\n";

// Test 1: Basic try/catch
try {
    print "In try block";
    throw "Something went wrong!";
    print "This should not print";
} catch (e) {
    print "Caught error: " + e;
}

print "";

// Test 2: Division by zero
fn safe_divide(a, b) {
    try {
        if b == 0 {
            throw "Division by zero!";
        }
        return a / b;
    } catch (err) {
        print "Error in divide: " + err;
        return 0;
    }
}

let result1 = safe_divide(10, 2);
print "10 / 2 = " + str(result1);

let result2 = safe_divide(10, 0);
print "10 / 0 = " + str(result2);

print "";

// Test 3: File operations with error handling
fn safe_read(path) {
    try {
        return read(path);
    } catch (e) {
        print "Failed to read file: " + e;
        return "";
    }
}

let content = safe_read("/tmp/nonexistent.txt");
print "File content: '" + content + "'";

print "";

// Test 4: Nested try/catch
try {
    print "Outer try";
    try {
        print "Inner try";
        throw "Inner error";
    } catch (e) {
        print "Inner catch: " + e;
        throw "Re-throwing from inner";
    }
} catch (e) {
    print "Outer catch: " + e;
}

print "\n=== All error handling tests passed! ===";
