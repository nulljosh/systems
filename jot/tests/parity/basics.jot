# Basic variable and arithmetic tests
let x = 10
let y = 20
print x + y
print x - y
print x * y
print x % 3

# String operations
let name = "jot"
print "hello " + name
print len(name)

# Booleans
print true
print false
print true and false
print true or false
print not true

# Null
print null

# Type coercion in print
print 42
print 3.14
print "string"
