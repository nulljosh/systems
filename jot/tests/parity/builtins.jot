# Builtin function parity tests

# Math
print abs(-42)
print floor(3.7)
print ceil(3.2)
print round(3.5)
print pow(2, 10)
print sqrt(144)
print min(3, 7)
print max(3, 7)

# String ops
print len("hello")
print str(42)
print str(true)
print str(null)

# Type checking
print type(42)
print type("hello")
print type(true)
print type(null)
print type([1, 2])
print type({x: 1})

# String methods
print "HELLO".lower()
print "hello".upper()
print "  hello  ".trim()
print "hello world".contains("world")
print "hello".replace("l", "r")

# Split and join
let parts = split("a,b,c", ",")
print len(parts)
print parts[0]
print parts[2]
print join(parts, "-")
