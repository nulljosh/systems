# Error handling: try/catch/throw (try/catch/throw)

# basic try/catch
try {
    print "before throw"
    throw "something went wrong"
    print "after throw"
} catch (e) {
    print "caught: " + e
}

# try/catch with function
fn safe_divide(a, b) {
    if b == 0 {
        throw "division by zero"
    }
    return a / b
}

try {
    print safe_divide(10, 2)
    print safe_divide(10, 0)
} catch (e) {
    print "error: " + e
}

# control flow after catch
print "after catch"

# standard keywords work too
try {
    throw "standard throw"
} catch (err) {
    print "std caught: " + err
}

# nested try/catch
try {
    try {
        throw "inner"
    } catch (e) {
        print "inner caught: " + e
        throw "rethrown"
    }
} catch (e) {
    print "outer caught: " + e
}
