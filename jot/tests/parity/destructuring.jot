// Array destructuring
let arr = [1, 2, 3]
let [a, b, c] = arr
print a
print b
print c

// Array destructuring with rest
let [first, ...rest] = [10, 20, 30, 40]
print first
print rest

// Object destructuring
let obj = {x: 100, y: 200}
let {x, y} = obj
print x
print y

// Destructuring with missing values
let [p, q, r] = [7, 8]
print p
print q
print r

// Empty rest
let [only, ...empty] = [42]
print only
print empty
