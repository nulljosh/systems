# Closure and higher-order function tests.
#
# Bug note: jot does NOT support true lexical closures -- inner functions
# cannot capture variables from the enclosing function's scope at the time
# the inner function is defined. Attempting to reference such variables
# results in: "undefined variable '<name>'"
#
# The tests below use patterns that ARE supported:
#   - Functions as first-class values (pass/store/call)
#   - Higher-order functions (apply, apply_twice)
#   - Mutable state via class instances (counter pattern)
#   - Map/filter/reduce patterns via explicit loops

# --- Functions as first-class values: pass to HOF ---
fn apply(f, val) {
    return f(val)
}

fn double(x) { return x * 2 }
fn square(x) { return x * x }
fn negate(x) { return x * -1 }

print apply(double, 7)
print apply(square, 5)
print apply(negate, 10)

# --- apply_twice: compose f with itself ---
fn apply_twice(f, x) {
    return f(f(x))
}
print apply_twice(double, 3)
print apply_twice(square, 2)

# --- Counter pattern: mutable state per class instance ---
# Simulates closure-with-mutable-state using this fields.
class Counter {
    fn init(start) {
        this.count = start
    }
    fn increment() {
        this.count += 1
        return this.count
    }
    fn decrement() {
        this.count -= 1
        return this.count
    }
    fn get() {
        return this.count
    }
    fn reset() {
        this.count = 0
    }
    fn add(n) {
        this.count += n
        return this.count
    }
}

let c = new Counter(0)
print c.increment()
print c.increment()
print c.increment()
print c.get()
print c.decrement()
print c.get()
c.reset()
print c.get()
print c.add(5)

# Two independent counters -- each instance has isolated state.
let c1 = new Counter(0)
let c2 = new Counter(100)
print c1.increment()
print c2.decrement()
print c1.get()
print c2.get()

# --- Filter-like pattern: iterate and conditionally print ---
fn print_evens(arr) {
    for item in arr {
        if item % 2 == 0 {
            print item
        }
    }
}

print_evens([1, 2, 3, 4, 5, 6, 7, 8])

# --- Reduce-like pattern: fold array into single value ---
fn reduce_sum(arr) {
    let acc = 0
    for item in arr {
        acc += item
    }
    return acc
}

print reduce_sum([1, 2, 3, 4, 5])
print reduce_sum([10, 20, 30])

# --- Map-like pattern: transform each element inline ---
fn sum_doubled(arr) {
    let acc = 0
    for item in arr {
        acc += item * 2
    }
    return acc
}
print sum_doubled([1, 2, 3, 4, 5])
