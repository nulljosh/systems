# Built-in functions

# len
print len("hello")
print len([1, 2, 3])
print len([])

# str
print str(42)
print str(true)
print str(null)

# int
print int(3.7)
print int("42")

# type
print type(42)
print type("hello")
print type(true)
print type(null)
print type([1, 2])

# range
print range(5)
print range(2, 5)

# push / pop
let arr = [1, 2, 3]
push(arr, 4)
print arr
print pop(arr)
print arr

# split / join
let parts = split("a-b-c", "-")
print parts
print join(parts, ", ")

# slice (string)
print slice("hello world", 0, 5)
print slice("hello world", 6)

# slice (array)
print slice([10, 20, 30, 40, 50], 1, 3)

# keys / values / has
let obj = {name: "carl", age: 65}
print has(obj, "name")
print has(obj, "missing")

# math
print abs(-5)
print abs(5)
print floor(3.7)
print ceil(3.2)
print round(3.5)
print round(3.4)
print min(3, 7)
print max(3, 7)
print sqrt(16)
print pow(2, 10)

# sort / reverse
print sort([3, 1, 4, 1, 5])
print reverse([1, 2, 3])
