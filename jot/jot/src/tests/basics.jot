# Variables, arithmetic, strings, booleans, null

# let (let)
let x = 10
let y = 3
print x
print y

# arithmetic
print x + y
print x - y
print x * y
print x / y
print x % y

# compound assignment
x += 5
print x
x -= 2
print x
x *= 3
print x
x /= 9
print x

# strings
let name = "Jung"
print name
print "Hello, " + name

# string interpolation
let age = 26
print "Name: ${name}, Age: ${age}"

# booleans
print true
print false
print true and true
print true and false
print false or true
print not false

# null / null
print null
let nothing = null
print nothing

# ternary
print true ? "yes" : "no"
print false ? "yes" : "no"
print 1 > 0 ? "greater" : "less"

# comparisons
print 5 == 5
print 5 != 3
print 5 > 3
print 5 < 3
print 5 >= 5
print 3 <= 5

# negative numbers
print -42
let neg = -7
print neg
