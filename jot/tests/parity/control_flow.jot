# Control flow parity tests

# If/else
let x = 10
if x > 5 {
    print "big"
} else {
    print "small"
}

# While loop
let i = 0
while i < 5 {
    i += 1
}
print i

# For loop
let sum = 0
for n in [1, 2, 3, 4, 5] {
    sum += n
}
print sum

# Break
let found = -1
for val in [10, 20, 30, 40, 50] {
    if val == 30 {
        found = val
        break
    }
}
print found

# Continue
let even_sum = 0
for n in range(1, 11) {
    if n % 2 != 0 {
        continue
    }
    even_sum += n
}
print even_sum

# Ternary
print 1 > 0 ? "yes" : "no"
print 0 > 1 ? "yes" : "no"

# Nested if
let val = 15
if val > 20 {
    print "high"
} else if val > 10 {
    print "medium"
} else {
    print "low"
}
