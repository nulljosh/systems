# Array and object parity tests

# Arrays
let arr = [1, 2, 3, 4, 5]
print arr[0]
print arr[4]
print len(arr)

# Sort and reverse
let nums = [5, 3, 1, 4, 2]
let sorted = sort(nums)
print sorted[0]
print sorted[4]

# Join
print join(["a", "b", "c"], "-")

# Objects
let obj = {name: "jot", version: 4}
print obj.name
print obj.version

# Object mutation
obj.name = "jot-lang"
print obj.name

# Nested
let nested = {a: {b: {c: 42}}}
print nested.a.b.c

# Range
let r = range(0, 5)
print len(r)
print r[0]
print r[4]
