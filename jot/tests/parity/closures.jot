# Closure parity tests

# Counter factory
fn make_counter() {
    let count = 0
    fn increment() {
        count += 1
        return count
    }
    return increment
}

let c1 = make_counter()
let c2 = make_counter()
print c1()
print c1()
print c1()
print c2()
print c2()

# Closure over parameter
fn make_adder(x) {
    fn add(y) {
        return x + y
    }
    return add
}

let add5 = make_adder(5)
let add10 = make_adder(10)
print add5(3)
print add10(3)
print add5(add10(1))

# Nested closure
fn outer(a) {
    fn middle(b) {
        fn inner(c) {
            return a + b + c
        }
        return inner
    }
    return middle
}

let f = outer(1)
let g = f(2)
print g(3)
print g(10)
