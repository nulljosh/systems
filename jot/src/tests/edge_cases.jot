# Edge cases: empty strings, negatives, booleans, nested access, escapes,
# zero division (guarded), large numbers, nested calls, variable shadowing

# --- Empty string operations ---
let s = ""
print s
print len(s)
print s + "hello"
print "hello" + s
print s == ""
print s == "x"

# --- Negative number arithmetic ---
print -1 + -2
print -10 * -3
print -10 / 2
print -10 / -5
print -7 % 3
print 7 % -3
print abs(-42)
let neg = -100
print neg + 50
print neg * -1

# --- Boolean coercion edge cases ---
# 0 and "" are falsy; 1, "x", [1] are truthy; null and [] are falsy
print 0 ? "truthy" : "falsy"
print 1 ? "truthy" : "falsy"
print "" ? "truthy" : "falsy"
print "x" ? "truthy" : "falsy"
print null ? "truthy" : "falsy"
print [] ? "truthy" : "falsy"
print [1] ? "truthy" : "falsy"
print not 0
print not 1
print not null

# --- Deeply nested object access ---
let deep = {a: {b: {c: {d: 42}}}}
print deep.a.b.c.d

let matrix = {rows: [{vals: [1,2,3]}, {vals: [4,5,6]}]}
print matrix.rows[0].vals[1]
print matrix.rows[1].vals[2]

# --- String with special characters and escapes ---
let s1 = "hello\nworld"
print s1
let s2 = "tab\there"
print s2
let s3 = "quote: \"inside\""
print s3
let s4 = "backslash: \\"
print s4

# --- Zero division behavior (guarded with try/catch) ---
# Note: bare integer division by zero is not caught by the VM;
# guard with a conditional to avoid runtime crash.
fn safe_div(a, b) {
    if b == 0 {
        return "div_by_zero"
    }
    return a / b
}
print safe_div(10, 0)
print safe_div(10, 2)
print safe_div(0, 5)
print 0 / 1

# --- Large number arithmetic ---
let big = 1000000
print big * big
print big + 999999
print big - 1
print big / 1000
let neg_big = -1000000
print neg_big * 2
print abs(neg_big)

# --- Nested function calls (3+ deep) ---
fn add(a, b) { return a + b }
fn mul(a, b) { return a * b }
fn sub(a, b) { return a - b }
fn double2(x) { return x * 2 }
fn inc(x) { return x + 1 }
fn sq(x) { return x * x }

print add(mul(2, 3), sub(10, 4))
print double2(inc(sq(3)))
print mul(add(1, 2), add(3, 4))
print add(mul(add(1, 1), 3), sub(10, mul(2, 2)))

# --- Variable shadowing in nested scopes ---
# Function scope is properly isolated: each function has its own scope.
let x = 1
fn outer() {
    let x = 10
    fn inner() {
        let x = 100
        return x
    }
    return inner()
}
print x
print outer()
print x

# Bug note: let inside for/if blocks does NOT create a new scope --
# it mutates the closest existing binding for that name in the current frame.
# The variable declared in the outer scope gets overwritten.
let val = 42
for i in range(3) {
    let val = i * 10
}
print val

let y = 5
if true {
    let y = 99
}
print y
